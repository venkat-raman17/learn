---
/**
 * CONCEPT: Static Paths from Content Collections (Astro v6)
 *
 * In Astro v6 (Content Layer):
 * - entries use `.id` instead of `.slug`
 * - `render()` is imported from 'astro:content' (not called as a method on the entry)
 * - getStaticPaths() still provides build-time URL generation
 *
 * Each Markdown file becomes a URL:
 *   islands-architecture.md → /blog/islands-architecture
 */
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post); // Astro v6: render() imported, not a method
---

<Layout title={post.data.title} description={post.data.description}>
  <article>
    <header style="margin-bottom: 2rem;">
      <a href="/blog" style="color: #0066cc; font-weight: 500; text-decoration: none;">← Blog</a>
      <h1 style="margin: 1rem 0 0.5rem;">{post.data.title}</h1>
      <div style="display: flex; gap: 1rem; align-items: center; color: #666; font-size: 0.875rem;">
        <span>By {post.data.author}</span>
        <span>·</span>
        <time datetime={post.data.date}>
          {new Date(post.data.date).toLocaleDateString("en-US", { dateStyle: "long" })}
        </time>
      </div>
      <div style="margin-top: 0.75rem; display: flex; gap: 0.4rem;">
        {post.data.tags.map((tag: string) => (
          <span style="background: #f0f4ff; color: #0055aa; padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.78rem; font-weight: 600;">
            {tag}
          </span>
        ))}
      </div>
    </header>

    <div style="max-width: 65ch;" class="prose">
      <Content />
    </div>

    <aside
      style="margin-top: 2.5rem; background: #f8f9fb; border-left: 4px solid #22c55e; border-radius: 0 8px 8px 0; padding: 1rem 1.25rem; font-size: 0.85rem; color: #555;"
    >
      <strong>No JS was loaded to display this page.</strong> The Markdown was
      converted to HTML at build time. <code>render(post)</code> (Astro v6 API)
      returns a <code>Content</code> component that renders the compiled HTML.
    </aside>
  </article>

  <style>
    .prose h1, .prose h2, .prose h3 { margin-top: 1.5em; }
    .prose code {
      background: #f5f5f5;
      padding: 0.1em 0.3em;
      border-radius: 3px;
      font-size: 0.9em;
    }
    .prose pre {
      background: #1e1e1e;
      color: #d4d4d4;
      padding: 1rem;
      border-radius: 8px;
      overflow-x: auto;
    }
    .prose pre code { background: none; padding: 0; }
    .prose table { border-collapse: collapse; width: 100%; }
    .prose th, .prose td { border: 1px solid #e0e0e0; padding: 0.5rem 0.75rem; text-align: left; }
    .prose th { background: #f5f5f5; }
  </style>
</Layout>
